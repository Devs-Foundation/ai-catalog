# Catálogo de IA — environment
# Copy this file to `.env` and fill in your values.

# ── Required ──────────────────────────────────────────────
# PostgreSQL connection string used by the API server and scripts.
DATABASE_URL=postgres://user:password@localhost:5432/catalogo_ia

# ── Optional ──────────────────────────────────────────────
# Port the API server listens on (default: 5000).
PORT=5000

# development | production
NODE_ENV=development

# error | warn | info | debug
LOG_LEVEL=info

# Base path when the app is served under a sub-path (default: "/").
# BASE_PATH=/
